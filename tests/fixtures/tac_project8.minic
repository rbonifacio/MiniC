int add(int a, int b) { return a + b; }

int max(int a, int b) {
    if a >= b {
        return a;
    } else {
        return b;
    }
}

int sum_to(int n) {
    int total = 0;
    int i = 1;
    while i <= n {
        total = total + i;
        i = i + 1;
    }
    return total;
}

test "arithmetic and control flow" {
    assert add(2, 3) == 5;
    assert max(7, 4) == 7;
    assert sum_to(5) == 15;
}

void main() {
    print(add(2, 3));
}
